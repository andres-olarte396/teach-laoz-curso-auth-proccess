# ============================================================================
# L4OZ ECOSYSTEM - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Este archivo contiene las variables de entorno necesarias para los proyectos
# del ecosistema L4OZ. Copie este archivo a cada proyecto como .env y configure
# los valores según su entorno.
# ============================================================================

# ----------------------------------------------------------------------------
# CONFIGURACIÓN GENERAL
# ----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
APP_NAME=L4OZ-Service

# ----------------------------------------------------------------------------
# SERVIDOR
# ----------------------------------------------------------------------------
HOST=localhost
PORT=3000

# ----------------------------------------------------------------------------
# BASE DE DATOS
# ----------------------------------------------------------------------------
# PostgreSQL
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=laoz_db
DB_USER=laoz_user
DB_PASSWORD=changeme
DB_SYNC=false
DB_LOGGING=false

# MongoDB (si aplica)
MONGO_URI=mongodb://localhost:27017/laoz_db
MONGO_USER=laoz_user
MONGO_PASSWORD=changeme

# Redis (si aplica)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----------------------------------------------------------------------------
# JWT & SEGURIDAD
# ----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# Encriptación
ENCRYPTION_KEY=your-32-character-encryption-key
ENCRYPTION_ALGORITHM=aes-256-cbc

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8000
CORS_CREDENTIALS=true

# ----------------------------------------------------------------------------
# MICROSERVICIOS (URLs Internas)
# ----------------------------------------------------------------------------
API_GATEWAY_URL=http://localhost:3000
AUTH_API_URL=http://localhost:3001
AUTHORIZATION_API_URL=http://localhost:3002
USER_API_URL=http://localhost:3003
FILES_API_URL=http://localhost:3004
INSIGHTS_API_URL=http://localhost:3005
SECRETS_API_URL=http://localhost:3006

# ----------------------------------------------------------------------------
# ALMACENAMIENTO DE ARCHIVOS
# ----------------------------------------------------------------------------
# Local Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads
MAX_FILE_SIZE=10485760

# AWS S3 (si aplica)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=laoz-files

# Azure Blob Storage (si aplica)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=laoz-files

# ----------------------------------------------------------------------------
# EMAIL (Notificaciones)
# ----------------------------------------------------------------------------
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@laoz.com

# ----------------------------------------------------------------------------
# LOGGING & MONITOREO
# ----------------------------------------------------------------------------
# Sentry (si aplica)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Application Insights (si aplica)
APPINSIGHTS_INSTRUMENTATIONKEY=

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ----------------------------------------------------------------------------
# API KEYS & SERVICIOS EXTERNOS
# ----------------------------------------------------------------------------
# OpenAI (si aplica)
OPENAI_API_KEY=

# Stripe (si aplica)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# COLAS Y MENSAJERÍA
# ----------------------------------------------------------------------------
# RabbitMQ (si aplica)
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE=laoz_queue

# ----------------------------------------------------------------------------
# DESARROLLO & DEBUG
# ----------------------------------------------------------------------------
DEBUG=true
VERBOSE_LOGGING=true
ENABLE_PLAYGROUND=true
ENABLE_SWAGGER=true

# ----------------------------------------------------------------------------
# TESTING
# ----------------------------------------------------------------------------
TEST_DATABASE_URL=postgres://localhost:5432/laoz_test
TEST_JWT_SECRET=test-secret-key

# ----------------------------------------------------------------------------
# NOTAS
# ----------------------------------------------------------------------------
# - Nunca commitee este archivo con valores reales de producción
# - Use variables de entorno del sistema para secretos en producción
# - Genere claves únicas para cada entorno (dev, staging, production)
# - Cambie todas las contraseñas y secretos por defecto
# ============================================================================
